# Copy this file to .env.local and fill in real values, then restart `npm run dev`.
# .env.local is gitignored — never commit real secrets.

# Required — Supabase (auth + database)
# Get these from your Supabase project: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — Gemini (AI Studio) for /learn, /subjects, /assistant.
# Server-only: do NOT prefix with NEXT_PUBLIC_.
GOOGLE_GENERATIVE_AI_API_KEY=
